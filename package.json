{
  "name": "electron-scaffolding",
  "version": "1.0.0",
  "description": "",
  "main": "dist/main/main.js",
  "scripts": {
    "dev:start": "./scripts/dev-start.sh",
    "build": "npm run build:renderer && npm run build:main",
